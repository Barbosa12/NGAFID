# ── Feature extraction functions ────────────────────────────────────────────
def _slope_fast(col: np.ndarray) -> float:
    """Linear regression slope — direct formula, avoids np.polyfit overhead."""
    valid = col[np.isfinite(col)]
    n = len(valid)
    if n < 2:
        return 0.0
    x = np.arange(n, dtype=np.float64)
    xc = x - x.mean()
    denom = (xc * xc).sum()
    return float((xc * (valid - valid.mean())).sum() / denom) if denom > 0 else 0.0


def extract_repr_b(X_block: np.ndarray) -> np.ndarray:
    """Compute Repr B for a block of shape (N, 23, T) → (N, 184)."""
    N = X_block.shape[0]
    out = np.zeros((N, N_S * N_ST), dtype=np.float32)
    for i in range(N):
        row_idx = 0
        for s in range(N_S):
            col = X_block[i, s, :].astype(np.float64)
            valid = col[np.isfinite(col)]
            n = len(valid)
            if n == 0:
                row_idx += N_ST
                continue
            mn  = float(valid.mean())
            sd  = float(valid.std())  if n > 1 else 0.0
            mi  = float(valid.min())
            mx  = float(valid.max())
            rng = mx - mi
            sk  = float(sp_skew(valid))  if n > 3 else 0.0
            kt  = float(sp_kurt(valid))  if n > 3 else 0.0
            sl  = _slope_fast(col)
            out[i, row_idx:row_idx+N_ST] = [mn, sd, mi, mx, rng, sk, kt, sl]
            row_idx += N_ST
    return out


