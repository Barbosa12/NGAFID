# ── Build Repr F++ ───────────────────────────────────────────────────────────
CHT_IDX = [S_IDX[s] for s in CHT_SENSORS]  # indices in SENSORS list
EGT_IDX = [S_IDX[s] for s in EGT_SENSORS]

# Precompute all pairwise CHT differences and CHT-EGT same-cyl diffs
# X_raw shape: (N, 23, 2048)
CHT_PAIRS    = list(combinations(range(4), 2))  # 6 pairs: (0,1),(0,2),(0,3),(1,2),(1,3),(2,3)
CHTEGT_PAIRS = [(i, i) for i in range(4)]       # 4 same-cyl: (0,0),(1,1),(2,2),(3,3)

print(f'CHT pairs    : {len(CHT_PAIRS)} × {len(CROSS_STATS)} stats = {len(CHT_PAIRS)*len(CROSS_STATS)} features')
print(f'CHT-EGT pairs: {len(CHTEGT_PAIRS)} × {len(CROSS_STATS)} stats = {len(CHTEGT_PAIRS)*len(CROSS_STATS)} features')
print(f'Total cross  : {(len(CHT_PAIRS)+len(CHTEGT_PAIRS))*len(CROSS_STATS)} features')
print(f'Repr F++ dim : 184 + {(len(CHT_PAIRS)+len(CHTEGT_PAIRS))*len(CROSS_STATS)} = {184+(len(CHT_PAIRS)+len(CHTEGT_PAIRS))*len(CROSS_STATS)}')


def extract_diff_stats(sig: np.ndarray) -> list:
    """4 stats over a difference signal (T,): mean, std, range, slope."""
    valid = sig[np.isfinite(sig)]
    n = len(valid)
    if n < 2:
        return [0.0, 0.0, 0.0, 0.0]
    return [
        float(valid.mean()),
        float(valid.std()),
        float(valid.max() - valid.min()),
        _slope_fast(valid),
    ]


def extract_repr_fpp(X_block: np.ndarray) -> np.ndarray:
    """(N, 23, T) → (N, 224).  Repr B (184) + CHT diffs (24) + CHT-EGT diffs (16)."""
    N = X_block.shape[0]
    n_cross = (len(CHT_PAIRS) + len(CHTEGT_PAIRS)) * len(CROSS_STATS)  # 40
    cross   = np.zeros((N, n_cross), dtype=np.float32)

    for i in range(N):
        col_idx = 0
        # Block 1: CHT pairwise differences
        for a, b in CHT_PAIRS:
            diff = X_block[i, CHT_IDX[a], :].astype(np.float64) - \
                   X_block[i, CHT_IDX[b], :].astype(np.float64)
            cross[i, col_idx:col_idx+4] = extract_diff_stats(diff)
            col_idx += 4
        # Block 2: CHT-EGT same-cylinder differences
        for cyl in range(4):
            diff = X_block[i, CHT_IDX[cyl], :].astype(np.float64) - \
                   X_block[i, EGT_IDX[cyl], :].astype(np.float64)
            cross[i, col_idx:col_idx+4] = extract_diff_stats(diff)
            col_idx += 4

    return np.hstack([extract_repr_b(X_block), cross]).astype(np.float32)


print('Building Repr F++ (224-D)...')
t0 = time.time()
X_fpp = extract_repr_fpp(X_raw)   # (11446, 224)
print(f'Done in {time.time()-t0:.1f}s  |  shape={X_fpp.shape}  NaN={np.isnan(X_fpp).sum()}')
X_fpp = np.nan_to_num(X_fpp, nan=0.0, posinf=0.0, neginf=0.0)

# Save AD + FC
np.savez_compressed(SAVE / 'repr_Fpp_AD.npz', X=X_fpp,           y=y_ad,          folds=folds)
