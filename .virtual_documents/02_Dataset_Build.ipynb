for cid, w in cw_sorted[:5]:
    print(f'  Class {cid:2d} ({ID_TO_FAULT[cid][:35]:35s}) : w={w:.2f}  n={int((y_fc_anom==cid).sum())}')
print(f'  ...\nClass weights (FC) — top 5 lowest:')
for cid, w in cw_sorted[-5:]:
    print(f'  Class {cid:2d} ({ID_TO_FAULT[cid][:35]:35s}) : w={w:.2f}  n={int((y_fc_anom==cid).sum())}')


# ── Fold stratification verification ─────────────────────────────────────────
print(f'{'Fold':>6} | AD balance | FC top-2 share | FC rare (<150) coverage')
print('-' * 62)
for fold_id in range(N_FOLDS):
    m_test = folds == fold_id
    y_test_ad  = y_ad[m_test]
    y_test_fc  = y_fc[m_test & anom_mask]
    ad_ratio   = y_test_ad.sum() / len(y_test_ad)
    top2_share = ((y_test_fc == 14) | (y_test_fc == 18)).mean()   # intake gasket, rocker cover
    rare_cls   = [c for c, n in zip(classes, np.bincount(y_fc_anom, minlength=19)) if 0 < n < 150]
    rare_pres  = sum(1 for c in rare_cls if (y_test_fc == c).sum() > 0)
    print(f'{fold_id:>6} | {ad_ratio:.3f}      | {top2_share:.3f}           | {rare_pres}/{len(rare_cls)} rare classes')

