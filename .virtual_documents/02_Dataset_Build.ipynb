print(f'Top cross feature     : {cross_names[f_cross.argmax()]}  F={f_cross.max():.1f}')





# ── Anti-leakage scaler function ─────────────────────────────────────────────
def scale_fold(X: np.ndarray, folds_arr: np.ndarray, fold_id: int):
    """
    Returns (X_train_scaled, X_test_scaled, scaler) for one fold.
    Scaler is fit on train only — zero data leakage.
    """
    train_mask = folds_arr != fold_id
    test_mask  = folds_arr == fold_id
    scaler = StandardScaler()
    X_tr = scaler.fit_transform(X[train_mask])
    X_te = scaler.transform(X[test_mask])
    return X_tr, X_te, scaler, train_mask, test_mask


# ── Class weights for FC ──────────────────────────────────────────────────────
y_fc_anom  = y_fc[anom_mask]
classes    = np.unique(y_fc_anom)
cw         = compute_class_weight('balanced', classes=classes, y=y_fc_anom)
class_weights_fc = dict(zip(classes, cw))

print('Class weights (FC) — top 5 highest:')
