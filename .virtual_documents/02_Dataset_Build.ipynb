# ── Build Repr B_seg for N in {3, 5, 10} ────────────────────────────────────
def extract_repr_bseg(X_block: np.ndarray, n_seg: int) -> np.ndarray:
    """(N, 23, T) → (N, 23*8*n_seg).  Each segment is T//n_seg timesteps."""
    N, S, T = X_block.shape
    edges = np.linspace(0, T, n_seg + 1, dtype=int)
    parts = []
    for k in range(n_seg):
        seg = X_block[:, :, edges[k]:edges[k+1]]   # (N, 23, T_k)
        parts.append(extract_repr_b(seg))
    return np.hstack(parts).astype(np.float32)      # (N, 184*n_seg)


seg_summary = []
for n_seg in [3, 5, 10]:
    print(f'Building Repr B_seg N={n_seg}...')
    t0 = time.time()
    X_seg = extract_repr_bseg(X_raw, n_seg)
    elapsed = time.time() - t0

    # AD
    np.savez_compressed(SAVE / f'repr_Bseg{n_seg}_AD.npz',
        X=X_seg, y=y_ad, folds=folds)
    # FC
