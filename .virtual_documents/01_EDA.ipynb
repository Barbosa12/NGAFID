# 6 representative sensors
SHOW = ['E1 RPM', 'E1 CHT1', 'E1 EGT1', 'IAS', 'AltMSL', 'E1 FFlow']
show_idx = [S_IDX[s] for s in SHOW]

# Time axis (normalised to [0, 1])
